meta {
  name: Update
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/admin/articles?/update
  body: multipartForm
  auth: none
}

body:multipart-form {
  id: {{adminArticleId}}
  slug: tarte-pommes-test
  title: Tarte aux pommes (mise à jour)
  subtitle: Sous-titre modifié
  slices: 8,10
  price: 20.00
  category_id: 1
  details_html: <p>Description mise à jour</p>
}
