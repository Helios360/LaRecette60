meta {
  name: Sign Up
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/sign-up/email
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{userEmail}}",
    "password": "{{userPassword}}",
    "name": "{{userName}}",
    "phone": "{{userPhone}}"
  }
}
