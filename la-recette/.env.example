# --- Node runtime -----------------------------------------------------------
# Hostinger usually injects PORT; HOST=0.0.0.0 lets the app bind on it.
HOST=0.0.0.0
PORT=3000
# Public origin of the deployed site (used by SvelteKit for CSRF + better-auth).
ORIGIN=https://www.larecette60.com
# If the app sits behind Hostinger's reverse proxy (it does), keep this on
# so SvelteKit reads X-Forwarded-* headers correctly.
PROTOCOL_HEADER=x-forwarded-proto
HOST_HEADER=x-forwarded-host

# --- MySQL (Hostinger remote DB) -------------------------------------------
DB_HOST=mysql.hostinger-region.example.com
DB_PORT=3306
DB_NAME=u123456_larecette
DB_USER=u123456_larecette
DB_PASSWORD=change-me

# --- better-auth ------------------------------------------------------------
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-32-byte-random-string
BETTER_AUTH_URL=https://www.larecette60.com

# --- Uploads ----------------------------------------------------------------
# Absolute path is recommended in production so the app can find uploads
# regardless of cwd. Leave empty to default to <projectRoot>/uploads.
UPLOADS_DIR=
